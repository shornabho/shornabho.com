<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G3PLZ5208L"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G3PLZ5208L');
    </script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description or 'Swarnava Ghosh - Software Engineer and Hobbyist Photographer.' }}">
    <meta name="author" content="Swarnava Ghosh">
    <meta name="theme-color" content="#ffffff">

    <meta property="og:type" content="{{ ogType or 'website' }}">
    <meta property="og:url" content="https://shornabho.com{{ page.url }}">
    <meta property="og:title" content="{{ title or 'Swarnava Ghosh' }}">
    <meta property="og:description" content="{{ description or 'Software Engineer and Hobbyist Photographer.' }}">
    <meta property="og:image" content="https://shornabho.com/static/images/swarnava-ghosh.jpg">

    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://shornabho.com{{ page.url }}">
    <meta property="twitter:title" content="{{ title or 'Swarnava Ghosh' }}">
    <meta property="twitter:description" content="{{ description or 'Software Engineer and Hobbyist Photographer.' }}">
    <meta property="twitter:image" content="https://shornabho.com/static/images/swarnava-ghosh.jpg">

    <title>{% if title %}{{ title }} — Swarnava Ghosh{% else %}Swarnava Ghosh{% endif %}</title>

    <link rel="icon" type="image/x-icon" href="/static/images/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/static/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/static/images/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/static/images/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="alternate" type="application/atom+xml" href="/feed.xml" title="Swarnava Ghosh — Blog">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet"></noscript>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <h1 class="navbar-logo">
                <a href="/">Swarnava Ghosh</a>
            </h1>
            <ul class="navbar-menu">
                <li><a href="/shelf">Shelf</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/photography">Photography</a></li>
                <li><a href="/career">Career</a></li>
            </ul>
        </nav>
    </header>
    <main>
        {{ content | safe }}
    </main>
    <footer>
        <div class="footer-content">
            <div class="footer-links">
                <a href="https://linkedin.com/in/swarnava-ghosh" target="_blank" rel="noopener noreferrer">LinkedIn</a>
                <a href="https://github.com/shornabho" target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href="https://instagram.com/shornabho" target="_blank" rel="noopener noreferrer">Instagram</a>
            </div>
            <p class="footer-copyright">Swarnava Ghosh &copy; 2020 - <script>document.write(new Date().getFullYear())</script></p>
        </div>
    </footer>
</body>
</html>
